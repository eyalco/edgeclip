# ╔════════════════════════════════════════════════════════════╗
# ║  EdgeClip — Paperclip + Cloudflare Tunnel + PostgreSQL   ║
# ║  Copy to .env and fill in all values.                    ║
# ╚════════════════════════════════════════════════════════════╝

# ── PostgreSQL ────────────────────────────────────────────────
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=

# ── Cloudflare Tunnel ────────────────────────────────────────
# Get token: cloudflared tunnel token <TUNNEL_NAME>
CLOUDFLARE_TUNNEL_TOKEN=

# ── Paperclip Server ─────────────────────────────────────────
# Your public domain (must match the tunnel's public hostname)
PAPERCLIP_DOMAIN=paperclip.yourdomain.com

# Session signing secret for Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Encryption key for Paperclip's secret vault
# Generate: openssl rand -base64 32
# Optional on first run (auto-generated), but set it for reproducibility
PAPERCLIP_SECRETS_MASTER_KEY=

# JWT secret for local agent API authentication
# Generate: openssl rand -base64 32
# Falls back to BETTER_AUTH_SECRET if not set
PAPERCLIP_AGENT_JWT_SECRET=

# ── Claude Code ──────────────────────────────────────────────
# Generate on a machine with a browser: claude setup-token
# Required for headless servers where Claude Code can't open a browser
CLAUDE_CODE_OAUTH_TOKEN=

# ── Network ──────────────────────────────────────────────────
# Bind address for the Paperclip server.
# 127.0.0.1 = loopback only (default, secure for remote servers with tunnel)
# 0.0.0.0   = all interfaces (needed for local dev with Docker Desktop)
EDGECLIP_BIND_HOST=127.0.0.1
